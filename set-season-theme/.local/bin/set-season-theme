#!/usr/bin/bash

while [[ $# -gt 0 ]]; do
    case "$1" in
        -s|--season) season="$2"; shift 2 ;;
        *) echo "Unknown flag: $1"; shift ;;
    esac
done

if [[ "${season}" == autumn ]]; then
    season=fall;
fi

if [[ -z "${season:-}" ]]; then
    month=$(date +%m)
    case "$month" in
        12|01|02) season=winter ;;
        03|04|05) season=spring ;;
        06|07|08) season=summer ;;
        09|10|11) season=fall ;;
    esac
fi

mkdir -p "$HOME/.local/share/set-season-theme/"
touch "$HOME/.local/share/set-season-theme/last-season"
previous_season=$(cat "$HOME/.local/share/set-season-theme/last-season")

if [ "$previous_season" != "$season" ]; then # season has changed

# Frozen winter’s blue and white
winter_bright=ffffff
winter_dim=003a7f

# Spring is pink and purple bright
spring_bright=b57281
spring_dim=47248e

# Gilded warm are summer's nights
summer_bright=ffcba4
summer_dim=704f00

# Fall brings calming woodland sights
fall_bright=009150
fall_dim=692a12

bright="${season}_bright"
dim="${season}_dim"

#############################
########## Emacs ############
#############################

case "$season" in
  winter) dark_theme=ef-night        light_theme=ef-frost ;;
  spring) dark_theme=ef-dark         light_theme=ef-light ;;
  summer) dark_theme=ef-melissa-dark light_theme=ef-melissa-light ;;
  fall)   dark_theme=ef-autumn       light_theme=ef-day ;;
esac

cat > "$HOME/.config/emacs/season-colors.el" <<EOF
;;; -*- lexical-binding: t -*-
;; Autogenerated by set-season-theme

(setq season-bright "#${!bright}"
      season-dim "#${!dim}"
      season-dark-theme '${dark_theme}
      season-light-theme '${light_theme})
EOF

#############################
######### Hyprland  #########
#############################

cat > "$HOME/.config/hypr/archive/season.conf" <<EOF
# Autogenerated by set-season-theme

\$season-bright = rgb(${!bright})
\$season-dim = rgb(${!dim})
EOF

cat > "$HOME/.config/hypr/season.lua" <<EOF
-- Autogenerated by set-season-theme

season_bright = "#${!bright}"
season_dim = "#${!dim}"
EOF

#############################
########## Waybar ###########
#############################

cat > "$HOME/.config/waybar/season-waybar-colors.css" <<EOF
/* Autogenerated by set-season-theme */

@define-color season-bright #${!bright};
@define-color season-dim #${!dim};
EOF

#############################
########## Fuzzel ###########
#############################

sed -i "s/^border=.*/border=${!bright}ff/" "$HOME/.config/fuzzel/fuzzel.ini"
sed -i "s/^icon-theme=.*/icon-theme=BeautyLine${season^}/" "$HOME/.config/fuzzel/fuzzel.ini"

#############################
########### Dunst ###########
#############################

# vibe coded...

awk -v dim="${!dim}" -v bright="${!bright}" -v season="${season^}" '
/^\[urgency_low\]/     { section="low" }
/^\[urgency_normal\]/  { section="normal" }
/^\[Icons\]/           { section="icons" }
/^\[/ && $0 !~ /\[urgency_(low|normal)\]/ && $0 !~ /\[Icons\]/ { section="" }
section=="low"    && /frame_color/    { $0="    frame_color = \"#" dim "\"" }
section=="low"    && /highlight/      { $0="    highlight = \"#" dim "\"" }
section=="normal" && /frame_color/    { $0="    frame_color = \"#" bright "\"" }
section=="normal" && /highlight/      { $0="    highlight = \"#" bright "\"" }
section=="icons" && /^[[:space:]]*icon_theme/ { $0="    icon_theme = \"BeautyLine" season "\"" }
{ print }
' "$HOME/.config/dunst/dunstrc" > dunstrc.tmp && mv dunstrc.tmp "$HOME/.config/dunst/dunstrc"

echo "$season" > "$HOME/.local/share/set-season-theme/last-season"

fi

#############################
######## Hyprpaper ##########
#############################

# Always change hyprpaper on login, regardless of season change

wallpapers=("$HOME/Pictures/wallpapers/$season-"*)
if [[ ! -f ${wallpapers[0]} ]]; then
    echo "No wallpapers for season '$season' found." >&2
    exit 1
fi
wallpaper=${wallpapers[RANDOM % ${#wallpapers[@]}]}

cat > "$HOME/.config/hypr/hyprpaper.conf" <<EOF
# Autogenerated by set-season-theme

wallpaper {
	  monitor = eDP-1
	  path = $wallpaper
}

splash = false
EOF

exit 0
